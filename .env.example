# ═══════════════════════════════════════════════════
#  CONSULTORIO PEDIÁTRICO — CONFIGURACIÓN
#  Copia este archivo como ".env" y completa los valores
#  NUNCA subas el archivo .env a Git
# ═══════════════════════════════════════════════════

# ─── BASE DE DATOS ───────────────────────────────
DB_NAME=consultorio_db
DB_USER=medico
DB_PASSWORD=CambiarEstaPasswordSegura123!
DB_PORT=5432

# ─── BACKEND / API ───────────────────────────────
# Genera una clave secreta fuerte (mínimo 32 caracteres)
# Puedes generarla con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=reemplaza-con-una-clave-secreta-de-al-menos-32-caracteres-aqui
API_PORT=8000

# ─── DATOS DEL MÉDICO ────────────────────────────
MEDICO_NOMBRE=Dr. Juan Pérez
MEDICO_ESPECIALIDAD=Cirugía Pediátrica
MEDICO_CEDULA=12345
MEDICO_TEL=809-000-0000
MEDICO_EMAIL=drjuanperez@consultorio.com
MEDICO_DIRECCION=Av. Principal 123, Consultorio 4-B, Santo Domingo

# ─── FRONTEND / WEB ──────────────────────────────
WEB_PORT=80

# ─── CORS (dominios permitidos) ──────────────────
CORS_ORIGINS=http://localhost,http://localhost:80,http://tu-dominio.com

# ─── PGADMIN (panel de base de datos) ────────────
PGADMIN_EMAIL=admin@consultorio.com
PGADMIN_PASSWORD=AdminPassword123!
PGADMIN_PORT=5050

# ─── WHATSAPP (Twilio — opcional) ────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── EMAIL (SMTP — opcional) ─────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucorreo@gmail.com
SMTP_PASSWORD=tu-app-password-de-gmail
SMTP_FROM=Consultorio Pediátrico <tucorreo@gmail.com>
